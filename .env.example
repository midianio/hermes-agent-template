# ── Required: at least one LLM provider key ─────────────────────────────────

# Recommended: OpenRouter (access to all models via one key)
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=openai/gpt-4o-mini

# Or: direct OpenAI
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Or: direct Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-5

# ── Optional: Tool APIs ──────────────────────────────────────────────────────

# Web search (pick one or more)
EXA_API_KEY=
FIRECRAWL_API_KEY=
PARALLEL_API_KEY=

# Image generation
FAL_KEY=

# Cross-session user modeling
HONCHO_API_KEY=

# GitHub (higher rate limits for code tools)
GITHUB_TOKEN=

# ── Optional: Browser automation ─────────────────────────────────────────────
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Gateway security ──────────────────────────────────────────────────────────
# Set to false and configure allowlists if you want to restrict access
GATEWAY_ALLOW_ALL_USERS=true

# ── Hermes serve auth (required for Desktop + browser on the public URL) ─────
# Hermes Desktop and the web UI sign in through these — separate from ADMIN_PASSWORD.
# For public Railway URLs, prefer OAuth: run `hermes dashboard register` and set
# HERMES_DASHBOARD_OAUTH_CLIENT_ID + HERMES_DASHBOARD_PUBLIC_URL=https://your-app.up.railway.app
# For Tailscale/VPN-only access, basic auth is fine:
# HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
# HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=choose-a-strong-password
# HERMES_DASHBOARD_BASIC_AUTH_SECRET=<openssl rand -base64 32>
# HERMES_DASHBOARD_PUBLIC_URL=https://your-app.up.railway.app

# ── Optional: API server (OpenAI-compatible clients, gateway proxy mode) ─────
# API_SERVER_ENABLED=true
# API_SERVER_HOST=0.0.0.0
# API_SERVER_PORT=8642
# API_SERVER_KEY=<openssl rand -hex 32>

# ── Terminal backend ──────────────────────────────────────────────────────────
# Options: local, docker, modal, ssh
TERMINAL_ENV=local
TERMINAL_TIMEOUT=60
